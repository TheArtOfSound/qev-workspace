{
  "name": "qev-workspace-monorepo",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm run build:packages && pnpm --filter @qev-workspace/relay build && pnpm --filter @qev-workspace/web build",
    "build:packages": "pnpm --filter @qev-workspace/protocol build && pnpm --filter @qev-workspace/crypto build",
    "build:web": "pnpm --filter @qev-workspace/web build",
    "build:relay": "pnpm --filter @qev-workspace/protocol build && pnpm --filter @qev-workspace/relay build",
    "dev:host-desktop": "pnpm --filter @qev-workspace/host-desktop dev",
    "build:host-desktop": "pnpm --filter @qev-workspace/host-desktop build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "build:host-agent": "pnpm --filter @qev-workspace/host-agent build",
    "dev:host-agent": "pnpm --filter @qev-workspace/host-agent dev",
    "audit:qev": "node scripts/qev-audit.mjs",
    "smoke:offline": "node scripts/qev-offline-smoke.mjs",
    "smoke:ui": "node scripts/qev-ui-smoke.mjs",
    "smoke:live": "node scripts/qev-live-relay-smoke.mjs",
    "verify:qev": "pnpm run build:packages && pnpm --filter @qev-workspace/web typecheck && pnpm run build:web && pnpm run smoke:offline && pnpm run smoke:ui && pnpm run smoke:responsive",
    "verify:qev:live": "pnpm run verify:qev && pnpm run smoke:live",
    "smoke:relay": "node scripts/qev-relay-ttl-smoke.mjs",
    "smoke:responsive": "node scripts/qev-responsive-smoke.mjs"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.8.3"
  }
}
