}

.status-card {
  padding: 10px !important;
}

.status-card strong {
  font-size: 18px !important;
}

.status-card small {
  font-size: 10px !important;
}

/* Status/readiness: stop narrow card text stacking. */
.operator-strip {
  grid-template-columns: minmax(300px, 0.8fr) minmax(0, 1.2fr) !important;
  align-items: stretch !important;
}

.next-action-card {
  min-height: 72px !important;
}

.readiness-strip {
  display: grid !important;
  grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
  gap: 8px !important;
}

.readiness-card {
  min-height: 72px !important;
  padding: 11px 10px !important;
  overflow: hidden !important;
}

.readiness-card span {
  font-size: 9px !important;
  line-height: 1 !important;
}

.readiness-card strong {
  font-size: 12px !important;
  line-height: 1.15 !important;
  overflow-wrap: normal !important;
  word-break: normal !important;
}

.readiness-card small {
  display: none !important;
}

.next-action-card small {
  max-width: 95% !important;
}

/* Main workspace: make remote screen dominant. */
.shell[data-section="workspace"] .grid {
  position: relative !important;
}

.shell[data-section="workspace"] .remote-panel,
.shell[data-section="workspace"] .screen-panel,
.shell[data-section="workspace"] .workspace-panel {
  min-height: calc(100vh - 240px) !important;
}

.shell[data-section="workspace"] .remote-panel video,
.shell[data-section="workspace"] .remote-panel canvas,
.shell[data-section="workspace"] .screen-panel video,
.shell[data-section="workspace"] .screen-panel canvas {
  min-height: calc(100vh - 315px) !important;
}

/* Local camera becomes a true picture-in-picture card. */
.shell[data-section="workspace"] .local-panel,
.shell[data-section="workspace"] .local-media-panel {
  position: absolute !important;
  right: 26px !important;
  bottom: 26px !important;
  width: 260px !important;
  min-height: 148px !important;
  max-width: 260px !important;
  padding: 10px !important;
  border-radius: 14px !important;
  z-index: 30 !important;
  background: #17191e !important;
