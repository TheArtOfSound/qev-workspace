}

.shell[data-section="workspace"] .local-panel p,
.shell[data-section="workspace"] .local-media-panel p {
  font-size: 10px !important;
  line-height: 1.25 !important;
  overflow-wrap: normal !important;
  word-break: normal !important;
}

/* Prevent huge empty vertical feel on desktop. */
.panel {
  overflow: hidden !important;
}

/* Wider screens can carry status cards without wrapping. */
@media (min-width: 1400px) {
  .readiness-card strong {
    font-size: 13px !important;
  }

  .readiness-card span {
    font-size: 10px !important;
  }
}

/* Medium screens: wrap readiness into useful rows instead of crushing text. */
@media (max-width: 1250px) {
  .operator-strip {
    grid-template-columns: 1fr !important;
  }

  .readiness-strip {
    grid-template-columns: repeat(5, minmax(110px, 1fr)) !important;
  }
}
