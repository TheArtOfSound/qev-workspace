  letter-spacing: -0.01em !important;
}

.remote-panel,
.screen-panel,
.workspace-panel {
  min-height: calc(100vh - 252px) !important;
}

.remote-panel video,
.remote-panel canvas,
.screen-panel video,
.screen-panel canvas {
  min-height: calc(100vh - 330px) !important;
}

/* Kill the awkward local preview covering the main screen. */
.local-panel,
.local-media-panel {
  max-width: 320px !important;
}

.shell[data-section="workspace"] .local-panel,
.shell[data-section="workspace"] .local-media-panel {
  position: absolute !important;
  right: 28px !important;
  bottom: 28px !important;
  width: 320px !important;
  min-height: 170px !important;
  z-index: 20 !important;
}

/* Inputs/buttons: quieter. */
input,
textarea,
select {
  background: #111216 !important;
  border: 1px solid rgba(255, 255, 255, 0.09) !important;
  color: #f4f5f6 !important;
  border-radius: 10px !important;
}

button {
  border-radius: 10px !important;
  box-shadow: none !important;
}

/* Responsive: stack cleanly. */
@media (max-width: 1000px) {
  .shell {
    padding: 12px !important;
  }

  .workspace-chrome {
    position: static !important;
    width: auto !important;
    margin-bottom: 12px !important;
  }

  .workspace-switcher {
    display: grid !important;
    grid-template-columns: repeat(5, 1fr) !important;
  }

  .operator-strip,
  .hero {
    grid-template-columns: 1fr !important;
  }

  .readiness-strip {
    grid-template-columns: 1fr 1fr !important;
  }

  .shell[data-section="workspace"] .local-panel,
  .shell[data-section="workspace"] .local-media-panel {
    position: static !important;
    width: auto !important;
    max-width: none !important;
  }
}

/* qev-de-stack-pass-v1
   Fix cramped readiness cards, oversized local preview, and fake sidebar footer. */

.workspace-chrome::after {
  content: none !important;
  display: none !important;
}

/* Sidebar: less dead space, cleaner theme footer. */
.workspace-chrome {
  gap: 12px !important;
}

.theme-switcher {
  margin-top: auto !important;
}

/* Header: reduce height and visual noise. */
.hero {
  min-height: 68px !important;
  padding: 12px 14px !important;
  grid-template-columns: minmax(0, 1fr) 220px !important;
}

.hero h1 {
  font-size: 18px !important;
}

.hero .lede {
