/* qev-setup-overlap-fix-v1
   Smoke test found .session-panel intercepting clicks over .identity-panel.
   This hard-resets the Setup tab grid placement so panels cannot overlap. */

.shell[data-section="setup"] .grid {
  position: relative;
  display: grid !important;
  grid-template-columns: minmax(320px, 0.75fr) minmax(460px, 1.25fr) !important;
  grid-template-rows: minmax(0, 1fr) !important;
