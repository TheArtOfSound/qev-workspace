/* qev-security-control-layout-refinement-v2
   Fixes smashed security/control pages by overriding the old 3-column document grid
   and giving each active tab a real app workspace layout. */

.grid > .panel[data-section] {
  display: none;
}

.shell[data-section="workspace"] .grid > .panel[data-section="workspace"],
.shell[data-section="setup"] .grid > .panel[data-section="setup"],
.shell[data-section="security"] .grid > .panel[data-section="security"],
.shell[data-section="controls"] .grid > .panel[data-section="controls"],
.shell[data-section="logs"] .grid > .panel[data-section="logs"] {
  display: grid;
}

/* Base tab layout: one focused page, not a 3-column document. */
.shell[data-section] .grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  grid-auto-rows: auto;
  align-items: stretch;
}

/* Make every section fill the available tab width. */
.shell[data-section] .grid > .panel[data-section] {
  grid-column: 1 / -1;
  width: 100%;
  min-width: 0;
}

/* Fix smashed key/value rows everywhere. */
.kv {
  min-width: 0;
}

.kv span,
.kv strong {
  min-width: 0;
}

.kv strong {
  overflow-wrap: anywhere;
}

/* SECURITY TAB — user-first dashboard. */
.shell[data-section="security"] .grid {
  max-width: 1280px;
  width: 100%;
  justify-self: center;
}

.shell[data-section="security"] .consent-panel {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  align-content: start;
  overflow: auto;
}

.shell[data-section="security"] .consent-panel > h2 {
  grid-column: 1 / -1;
  position: sticky;
  top: 0;
  z-index: 2;
  background: var(--panel);
  border-bottom: 1px solid var(--line-strong);
  padding-bottom: 0.85rem;
}

/* Security status fields become cards. */
.shell[data-section="security"] .consent-panel > .kv {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.45rem;
  border: 1px solid var(--line);
  background: var(--panel-soft);
  padding: 0.9rem;
  min-height: 86px;
}

.shell[data-section="security"] .consent-panel > .kv span {
  font-size: 0.68rem;
  line-height: 1.25;
}

.shell[data-section="security"] .consent-panel > .kv strong {
  text-align: left;
  font-size: 0.88rem;
  line-height: 1.35;
}

/* Important actions and explanations take the full row. */
.shell[data-section="security"] .consent-panel > .safety-actions,
.shell[data-section="security"] .consent-panel > .safety-note,
.shell[data-section="security"] .consent-panel > .indicator {
  grid-column: 1 / -1;
}

.shell[data-section="security"] .consent-panel > .safety-actions {
  border: 1px solid var(--line-strong);
  padding: 0.85rem;
  background: var(--panel);
}

.shell[data-section="security"] .consent-panel > .safety-actions button {
  flex: 1 1 190px;
}

.shell[data-section="security"] .consent-panel > .safety-note {
  border: 1px dashed var(--line);
  background: var(--panel-soft);
  padding: 0.9rem;
}

/* Privacy boxes sit as organized cards, not one endless vertical blob. */
.shell[data-section="security"] .consent-panel > .privacy-box {
  grid-column: span 3;
  align-self: start;
}

.shell[data-section="security"] .privacy-box {
  display: grid;
  grid-template-columns: minmax(240px, 0.65fr) minmax(0, 1fr);
  gap: 0.9rem;
  align-items: start;
}

.shell[data-section="security"] .privacy-box > h3,
.shell[data-section="security"] .privacy-box > p,
.shell[data-section="security"] .privacy-box > label,
.shell[data-section="security"] .privacy-box > .button-row,
.shell[data-section="security"] .privacy-box > .media-notes {
  grid-column: 1;
}

.shell[data-section="security"] .privacy-box > .control-grid,
.shell[data-section="security"] .privacy-box > .kv {
  grid-column: 2;
}

.shell[data-section="security"] .privacy-box .control-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.shell[data-section="security"] .privacy-box .kv {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.35rem;
  border: 1px solid var(--line);
  background: var(--panel);
  padding: 0.75rem;
}

.shell[data-section="security"] .privacy-box .kv strong {
  text-align: left;
}

/* CONTROL TAB — two clear command consoles. */
.shell[data-section="controls"] .grid {
  max-width: 1280px;
  width: 100%;
  justify-self: center;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.shell[data-section="controls"] .control-permission-panel,
.shell[data-section="controls"] .control-legacy-panel {
  display: grid !important;
  grid-column: auto;
  align-content: start;
  overflow: auto;
}

.shell[data-section="controls"] .control-panel > h2 {
  position: sticky;
  top: 0;
  z-index: 2;
  background: var(--panel);
  border-bottom: 1px solid var(--line-strong);
  padding-bottom: 0.85rem;
}

.shell[data-section="controls"] .control-panel > p {
  margin: 0;
  color: var(--muted);
  border: 1px dashed var(--line);
  background: var(--panel-soft);
  padding: 0.9rem;
}

.shell[data-section="controls"] .control-panel .button-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.shell[data-section="controls"] .control-panel .button-row button {
  width: 100%;
}

.shell[data-section="controls"] .control-panel .control-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.shell[data-section="controls"] .control-panel .kv {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.35rem;
  border: 1px solid var(--line);
  background: var(--panel-soft);
  padding: 0.8rem;
}

.shell[data-section="controls"] .control-panel .kv strong {
  text-align: left;
}

.shell[data-section="controls"] .agent-command {
  max-height: 180px;
  overflow: auto;
  border: 1px solid var(--line);
  background: var(--panel-soft);
  padding: 0.9rem;
}

/* SETUP TAB — prevent same old skinny-column issue. */
.shell[data-section="setup"] .grid {
  max-width: 1180px;
  width: 100%;
  justify-self: center;
  grid-template-columns: minmax(300px, 0.75fr) minmax(420px, 1.25fr);
  gap: 14px;
}

.shell[data-section="setup"] .identity-panel,
.shell[data-section="setup"] .session-panel {
  grid-column: auto;
}

/* WORKSPACE TAB — give stage/chat real app proportions. */
.shell[data-section="workspace"] .grid {
  grid-template-columns: minmax(0, 1fr) minmax(320px, 420px);
  gap: 14px;
}

.shell[data-section="workspace"] .remote-stage {
  grid-column: 1;
}

.shell[data-section="workspace"] .chat-panel {
  grid-column: 2;
}

/* LOGS TAB. */
.shell[data-section="logs"] .grid {
  max-width: 1180px;
  width: 100%;
  justify-self: center;
}

.shell[data-section="logs"] .audit-panel {
  grid-column: 1 / -1;
}

/* Laptop / smaller browser widths: avoid squeezed columns entirely. */
@media (max-width: 1180px) {
  .shell {
    width: min(100% - 28px, 1120px);
    max-width: none;
  }

  .shell[data-section="security"] .consent-panel {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .shell[data-section="security"] .consent-panel > .privacy-box {
    grid-column: 1 / -1;
  }

  .shell[data-section="security"] .privacy-box {
    grid-template-columns: 1fr;
  }

  .shell[data-section="security"] .privacy-box > h3,
  .shell[data-section="security"] .privacy-box > p,
  .shell[data-section="security"] .privacy-box > label,
  .shell[data-section="security"] .privacy-box > .button-row,
  .shell[data-section="security"] .privacy-box > .media-notes,
  .shell[data-section="security"] .privacy-box > .control-grid,
  .shell[data-section="security"] .privacy-box > .kv {
    grid-column: 1;
  }

  .shell[data-section="controls"] .grid,
  .shell[data-section="setup"] .grid,
  .shell[data-section="workspace"] .grid {
    grid-template-columns: 1fr;
  }

  .shell[data-section="workspace"] .remote-stage,
  .shell[data-section="workspace"] .chat-panel {
    grid-column: 1;
  }
}

@media (max-width: 760px) {
  .shell[data-section="security"] .consent-panel {
    grid-template-columns: 1fr;
  }

  .shell[data-section="security"] .privacy-box .control-grid,
  .shell[data-section="controls"] .control-panel .control-grid,
  .shell[data-section="controls"] .control-panel .button-row {
    grid-template-columns: 1fr;
  }
}

/* qev-readiness-and-audit-clarity-v1 */
.operator-strip {
