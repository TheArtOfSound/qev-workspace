  color: var(--qev-text-soft) !important;
  letter-spacing: 0.08em !important;
}

.safety-line {
  margin-top: 6px !important;
  color: var(--qev-text-muted) !important;
  font-size: 12px !important;
}

.status-card {
  border-radius: var(--qev-radius-md) !important;
  background: var(--qev-surface-1) !important;
  border: 1px solid var(--qev-border-soft) !important;
  padding: 10px 12px !important;
}

.workspace-chrome {
  position: sticky;
  top: 0;
  z-index: 40;
