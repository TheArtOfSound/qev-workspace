  grid-area: identity !important;
  grid-column: 1 / 2 !important;
  grid-row: 1 / 2 !important;
  position: relative;
  z-index: 2;
  min-width: 0;
  pointer-events: auto;
}

.shell[data-section="setup"] .session-panel {
  grid-area: session !important;
  grid-column: 2 / 3 !important;
  grid-row: 1 / 2 !important;
  position: relative;
  z-index: 1;
  min-width: 0;
  pointer-events: auto;
}

.shell[data-section="setup"] .session-panel .control-grid,
.shell[data-section="setup"] .identity-panel .control-grid {
  max-width: 100%;
  min-width: 0;
}

@media (max-width: 1180px) {
  .shell[data-section="setup"] .grid {
    grid-template-columns: 1fr !important;
    grid-template-rows: auto auto !important;
    grid-template-areas:
      "identity"
      "session" !important;
    overflow: visible;
  }

  .shell[data-section="setup"] .identity-panel,
  .shell[data-section="setup"] .session-panel {
    grid-column: 1 / -1 !important;
    grid-row: auto !important;
  }
}

/* qev-slack-clean-pass-v1
   Goal: turn QEV from a scattered card dashboard into a cleaner workspace shell.
   This is CSS-only so it does not disturb the passing crypto/relay/WebRTC tests. */

:root {
  --qev-app-bg: #111214;
  --qev-surface-0: #16181b;
  --qev-surface-1: #1b1d21;
  --qev-surface-2: #22252a;
  --qev-border-soft: rgba(255, 255, 255, 0.08);
  --qev-border-strong: rgba(255, 255, 255, 0.14);
  --qev-text-main: #f3f4f6;
  --qev-text-muted: #a7abb3;
  --qev-text-soft: #777d87;
  --qev-accent: #d7ff5f;
  --qev-danger: #ff6363;
  --qev-radius-sm: 8px;
  --qev-radius-md: 12px;
  --qev-radius-lg: 16px;
}

body {
  background: #08090a !important;
}

.shell {
  min-height: 100vh;
  max-width: none !important;
  margin: 0 !important;
  padding: 18px 18px 18px 88px !important;
  background:
    radial-gradient(circle at top left, rgba(215, 255, 95, 0.045), transparent 320px),
    var(--qev-app-bg) !important;
  color: var(--qev-text-main);
}

/* Slim app rail like a real workspace product. */
.shell::before {
  content: "Q";
  position: fixed;
  left: 18px;
  top: 18px;
  width: 48px;
  height: 48px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: var(--qev-surface-2);
  border: 1px solid var(--qev-border-strong);
  color: var(--qev-accent);
  font-weight: 900;
  font-size: 24px;
  z-index: 50;
}

.shell::after {
  content: "";
  position: fixed;
  left: 18px;
  top: 78px;
  bottom: 18px;
  width: 48px;
  border-radius: 16px;
  background:
    linear-gradient(to bottom, rgba(255, 255, 255, 0.06), transparent),
    var(--qev-surface-0);
  border: 1px solid var(--qev-border-soft);
  z-index: 1;
}

.hero {
  min-height: 64px !important;
  padding: 12px 14px !important;
  margin-bottom: 10px !important;
  border-radius: var(--qev-radius-lg) !important;
  background: var(--qev-surface-0) !important;
  border: 1px solid var(--qev-border-soft) !important;
